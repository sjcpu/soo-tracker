  d.className='msg'+(role==='user'?' user':'');
  d.innerHTML=`<div class="avatar ${role==='ai'?'av-ai':'av-me'}">${role==='ai'?'AI':'나'}</div><div class="bubble ${role==='ai'?'bubble-ai':'bubble-me'}">${text.replace(/\n/g,'<br>')}</div>`;
  el.appendChild(d);el.scrollTop=el.scrollHeight;
}

