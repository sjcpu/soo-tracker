<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>포트폴리오</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{font-family:'Noto Sans KR',sans-serif;background:#f5f6fa;color:#1a1a2e;font-size:14px;line-height:1.5;min-height:100vh;padding-bottom:80px;}
.mono{font-family:'DM Mono',monospace;}

/* Top bar */
.topbar{background:#fff;padding:16px 20px 12px;border-bottom:1px solid #eef0f5;position:sticky;top:0;z-index:50;}
.topbar-title{font-size:17px;font-weight:700;color:#1a1a2e;letter-spacing:-0.3px;}
.topbar-sub{font-size:12px;color:#8a8fa8;margin-top:2px;}

/* Bottom nav */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid #eef0f5;display:flex;z-index:100;padding-bottom:env(safe-area-inset-bottom,0);}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:10px 4px 8px;font-size:10px;color:#aab0c4;cursor:pointer;border:none;background:none;transition:color .15s;}
.nav-btn.active{color:#5b5ef4;}
.nav-btn i{font-size:22px;}

/* Pages */
.page{display:none;padding:16px 16px 0;}
.page.active{display:block;}

/* Section label */
.sec-label{font-size:11px;font-weight:500;color:#aab0c4;letter-spacing:.06em;text-transform:uppercase;margin:20px 0 10px;}
.sec-label:first-child{margin-top:4px;}

/* Metric row */
.metric-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin-bottom:14px;}
.metric-card{background:#fff;border-radius:14px;padding:14px 16px;border:1px solid #eef0f5;}
.metric-label{font-size:11px;color:#8a8fa8;margin-bottom:5px;}
.metric-value{font-size:20px;font-weight:700;letter-spacing:-0.5px;}
.metric-sub{font-size:11px;color:#aab0c4;margin-top:3px;}
.up{color:#1cb37a;}
.down{color:#e85555;}
.warn{color:#e09a1a;}

/* Hero card */
.hero-card{background:#5b5ef4;border-radius:18px;padding:20px;margin-bottom:14px;color:#fff;}
.hero-label{font-size:12px;opacity:.75;margin-bottom:6px;}
.hero-value{font-size:30px;font-weight:700;letter-spacing:-1px;}
.hero-sub{font-size:12px;opacity:.7;margin-top:4px;}
.hero-row{display:flex;justify-content:space-between;margin-top:16px;}
.hero-stat{text-align:center;}
.hero-stat-val{font-size:15px;font-weight:700;}
.hero-stat-label{font-size:11px;opacity:.65;margin-top:2px;}

/* Card */
.card{background:#fff;border-radius:14px;border:1px solid #eef0f5;padding:14px 16px;margin-bottom:12px;}
.card-title{font-size:12px;font-weight:500;color:#8a8fa8;margin-bottom:12px;}

/* Asset item */
.asset-item{display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid #f3f4f8;}
.asset-item:last-child{border-bottom:none;}
.asset-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.asset-info{flex:1;min-width:0;}
.asset-name{font-size:13px;font-weight:500;color:#1a1a2e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.asset-meta{font-size:11px;color:#aab0c4;margin-top:2px;}
.asset-right{text-align:right;flex-shrink:0;}
.asset-value{font-size:13px;font-weight:500;color:#1a1a2e;}
.asset-ret{font-size:11px;margin-top:2px;}

/* Badge */
.badge{display:inline-block;font-size:10px;padding:2px 7px;border-radius:5px;font-weight:500;}
.b-risk{background:#fff0f0;color:#c0392b;}
.b-safe{background:#edfaf4;color:#0f6e56;}
.b-toss{background:#e8f0fe;color:#185fa5;}
.b-samsung{background:#eeedfe;color:#534AB7;}
.b-namu{background:#edfaf4;color:#0F6E56;}
.b-mirae{background:#faeeda;color:#633806;}

/* Bar */
.bar-row{display:flex;align-items:center;gap:8px;margin:6px 0;}
.bar-label{width:90px;font-size:12px;color:#8a8fa8;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.bar-track{flex:1;height:6px;background:#f0f1f5;border-radius:3px;overflow:hidden;}
.bar-fill{height:100%;border-radius:3px;}
.bar-pct{width:38px;text-align:right;font-size:12px;font-family:'DM Mono',monospace;color:#1a1a2e;}

/* Risk bar */
.risk-bar-wrap{margin:8px 0 4px;}
.risk-bar-track{height:10px;background:#f0f1f5;border-radius:5px;overflow:hidden;position:relative;}
.risk-bar-fill{height:100%;border-radius:5px;transition:width .6s;}
.risk-limit{position:absolute;top:-3px;bottom:-3px;width:2px;background:#e85555;border-radius:1px;}

/* Alert */
.alert{padding:11px 14px;border-radius:10px;font-size:13px;margin-bottom:10px;display:flex;gap:8px;align-items:flex-start;line-height:1.5;}
.a-warn{background:#fffbec;border:1px solid #f7d87a;color:#854F0B;}
.a-danger{background:#fff5f5;border:1px solid #f5b8b8;color:#A32D2D;}
.a-ok{background:#edfaf4;border:1px solid #9FE1CB;color:#085041;}
.a-info{background:#edf4ff;border:1px solid #B5D4F4;color:#0C447C;}

/* AI chat */
.ai-msgs{display:flex;flex-direction:column;gap:10px;margin-bottom:12px;max-height:320px;overflow-y:auto;}
.msg{display:flex;gap:8px;}
.msg.user{flex-direction:row-reverse;}
.avatar{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;}
.av-ai{background:#ede8ff;color:#534AB7;}
.av-me{background:#e3f9ef;color:#085041;}
.bubble{max-width:82%;padding:9px 12px;border-radius:10px;font-size:13px;line-height:1.55;}
.bubble-ai{background:#f7f8fc;color:#1a1a2e;border-radius:2px 10px 10px 10px;}
.bubble-me{background:#ede8ff;color:#1a1a2e;border-radius:10px 2px 10px 10px;}
.chat-input-row{display:flex;gap:8px;}
.chat-input{flex:1;background:#f5f6fa;border:1px solid #eef0f5;border-radius:10px;padding:10px 12px;color:#1a1a2e;font-family:'Noto Sans KR',sans-serif;font-size:13px;outline:none;}
.chat-input:focus{border-color:#5b5ef4;}
.btn-send{background:#5b5ef4;color:#fff;border:none;border-radius:10px;padding:10px 16px;font-size:13px;font-weight:500;cursor:pointer;font-family:'Noto Sans KR',sans-serif;white-space:nowrap;}
.btn-send:disabled{opacity:.5;}

/* Quick btn */
.quick-btns{display:flex;flex-direction:column;gap:7px;margin-bottom:14px;}
.quick-btn{background:#fff;border:1px solid #eef0f5;border-radius:10px;padding:11px 14px;font-size:13px;color:#1a1a2e;text-align:left;cursor:pointer;display:flex;align-items:center;gap:8px;font-family:'Noto Sans KR',sans-serif;}
.quick-btn:active{background:#f5f6fa;}

/* Form */
.form-group{margin-bottom:12px;}
.form-label{font-size:12px;color:#8a8fa8;margin-bottom:5px;display:block;}
.form-ctrl{width:100%;background:#f5f6fa;border:1px solid #eef0f5;border-radius:10px;padding:11px 14px;color:#1a1a2e;font-family:'Noto Sans KR',sans-serif;font-size:14px;outline:none;}
.form-ctrl:focus{border-color:#5b5ef4;background:#fff;}
.form-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;}
.btn-full{width:100%;background:#5b5ef4;color:#fff;border:none;border-radius:12px;padding:14px;font-size:15px;font-weight:500;cursor:pointer;font-family:'Noto Sans KR',sans-serif;margin-top:4px;}
.btn-full:active{opacity:.85;}
.btn-outline{width:100%;background:#fff;color:#5b5ef4;border:1px solid #5b5ef4;border-radius:12px;padding:12px;font-size:14px;font-weight:500;cursor:pointer;font-family:'Noto Sans KR',sans-serif;margin-bottom:8px;}
.btn-outline:active{background:#f0f0ff;}

/* Overlap */
.overlap-card{background:#fff;border-radius:14px;border:1px solid #eef0f5;padding:14px 16px;margin-bottom:10px;}
.overlap-title{font-size:13px;font-weight:500;color:#1a1a2e;margin-bottom:4px;}
.overlap-detail{font-size:12px;color:#8a8fa8;margin-bottom:6px;}
.overlap-tip{font-size:11px;color:#aab0c4;background:#f7f8fc;padding:8px 10px;border-radius:7px;}

/* Spinner */
.spinner{width:14px;height:14px;border:2px solid #e0e2f0;border-top-color:#5b5ef4;border-radius:50%;animation:spin .8s linear infinite;display:inline-block;}
@keyframes spin{to{transform:rotate(360deg)}}
.loading{display:flex;align-items:center;gap:8px;font-size:13px;color:#8a8fa8;}

/* Empty state */
.empty{text-align:center;padding:32px 16px;color:#aab0c4;font-size:13px;}
.empty i{font-size:36px;display:block;margin-bottom:10px;color:#d0d3e8;}

/* Delete btn */
.del-btn{background:none;border:none;color:#ccc;cursor:pointer;font-size:18px;padding:4px;}
.del-btn:active{color:#e85555;}
</style>
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <div class="topbar-title">내 포트폴리오</div>
  <div class="topbar-sub" id="topbar-sub">4개 계좌 통합 관리</div>
</div>

<!-- Pages -->
<div id="page-home" class="page active">
  <div class="sec-label">총 자산</div>
  <div class="hero-card">
    <div class="hero-label">총 평가금액</div>
    <div class="hero-value mono" id="h-total">—</div>
    <div class="hero-sub" id="h-total-sub">자산을 추가해주세요</div>
    <div class="hero-row">
      <div class="hero-stat"><div class="hero-stat-val mono" id="h-ret">—</div><div class="hero-stat-label">수익률</div></div>
      <div class="hero-stat"><div class="hero-stat-val mono" id="h-cnt">—</div><div class="hero-stat-label">보유 종목</div></div>
      <div class="hero-stat"><div class="hero-stat-val mono" id="h-risk">—</div><div class="hero-stat-label">IRP 위험자산</div></div>
    </div>
  </div>

  <div id="irp-alert"></div>

  <div class="sec-label">계좌별 비중</div>
  <div class="card"><div id="acct-bars"><div class="empty"><i class="ti ti-wallet" aria-hidden="true"></i>자산을 추가하면 표시됩니다</div></div></div>

  <div class="sec-label">주요 보유 자산</div>
  <div class="card" id="top-assets"><div class="empty"><i class="ti ti-chart-pie" aria-hidden="true"></i>자산을 추가해주세요</div></div>
</div>

<div id="page-assets" class="page">
  <div style="display:flex;gap:8px;margin-bottom:14px;overflow-x:auto;padding-bottom:4px;">
    <button class="badge b-samsung" style="padding:6px 14px;border:none;cursor:pointer;font-size:12px;white-space:nowrap;" onclick="setFilter('all')">전체</button>
    <button class="badge b-toss" style="padding:6px 14px;border:none;cursor:pointer;font-size:12px;white-space:nowrap;" onclick="setFilter('toss')">토스</button>
    <button class="badge b-samsung" style="padding:6px 14px;border:none;cursor:pointer;font-size:12px;white-space:nowrap;" onclick="setFilter('samsung')">삼성IRP</button>
    <button class="badge b-namu" style="padding:6px 14px;border:none;cursor:pointer;font-size:12px;white-space:nowrap;" onclick="setFilter('namu')">나무ISA</button>
    <button class="badge b-mirae" style="padding:6px 14px;border:none;cursor:pointer;font-size:12px;white-space:nowrap;" onclick="setFilter('mirae')">미래에셋</button>
  </div>
  <div class="card" id="assets-list"><div class="empty"><i class="ti ti-list" aria-hidden="true"></i>자산 없음</div></div>
</div>

<div id="page-overlap" class="page">
  <div id="overlap-body"><div class="empty" style="padding-top:40px;"><i class="ti ti-copy" aria-hidden="true"></i>분석할 자산을 추가해주세요</div></div>
</div>

<div id="page-ai" class="page">
  <div class="sec-label">빠른 분석</div>
  <div class="quick-btns">
    <button class="quick-btn" onclick="qask('내 포트폴리오 중복투자 문제를 분석하고 정리 방법 알려줘')"><i class="ti ti-copy" aria-hidden="true" style="color:#5b5ef4;font-size:18px;"></i>중복투자 정리</button>
    <button class="quick-btn" onclick="qask('현재 시장 상황에서 내 포트폴리오 매도/매수 추천해줘')"><i class="ti ti-trending-up" aria-hidden="true" style="color:#1cb37a;font-size:18px;"></i>매수/매도 추천</button>
    <button class="quick-btn" onclick="qask('IRP·ISA·CMA·직투 계좌별 세금 최적화 방법 알려줘')"><i class="ti ti-receipt-tax" aria-hidden="true" style="color:#e09a1a;font-size:18px;"></i>계좌별 절세 전략</button>
    <button class="quick-btn" onclick="qask('내 포트폴리오 리스크 분석하고 분산 개선안 제시해줘')"><i class="ti ti-shield" aria-hidden="true" style="color:#e85555;font-size:18px;"></i>리스크 분석</button>
    <button class="quick-btn" onclick="qask('2026년 글로벌 경제 고려해서 내 포트폴리오 조정 의견 줘')"><i class="ti ti-world" aria-hidden="true" style="color:#8a8fa8;font-size:18px;"></i>거시경제 기반 조정</button>
  </div>
  <div class="sec-label">AI 어드바이저</div>
  <div class="card" style="padding:14px;">
    <div class="ai-msgs" id="ai-msgs">
      <div class="msg">
        <div class="avatar av-ai">AI</div>
        <div class="bubble bubble-ai">안녕하세요! 투자 어드바이저입니다. 자산 추가 후 빠른 분석 버튼을 눌러보세요!</div>
      </div>
    </div>
    <div class="chat-input-row">
      <input class="chat-input" id="ai-in" type="text" placeholder="질문을 입력하세요..." onkeydown="if(event.key==='Enter')sendAI()">
      <button class="btn-send" id="ai-btn" onclick="sendAI()">전송</button>
    </div>
  </div>
</div>

<div id="page-add" class="page">
  <div class="sec-label">자산 직접 입력</div>
  <div class="card">
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">계좌</label>
        <select class="form-ctrl" id="f-acct">
          <option value="toss">토스직투</option>
          <option value="samsung">삼성증권 IRP</option>
          <option value="namu">나무증권 ISA</option>
          <option value="mirae">미래에셋 CMA</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">유형</label>
        <select class="form-ctrl" id="f-type">
          <option value="domestic_stock">국내주식</option>
          <option value="us_stock">미국주식</option>
          <option value="etf_domestic">국내ETF</option>
          <option value="etf_us">미국ETF</option>
          <option value="fund">펀드</option>
          <option value="bond_fund">채권형</option>
          <option value="tdf">TDF</option>
          <option value="deposit">예금</option>
          <option value="cash">CMA/현금</option>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">종목명/상품명</label>
      <input class="form-ctrl" id="f-name" type="text" placeholder="예: 삼성전자, TIGER미국S&P500">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">수량/좌수</label>
        <input class="form-ctrl" id="f-qty" type="number" placeholder="0">
      </div>
      <div class="form-group">
        <label class="form-label">평균단가 (원)</label>
        <input class="form-ctrl" id="f-cost" type="number" placeholder="0">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">평가금액 (원)</label>
        <input class="form-ctrl" id="f-value" type="number" placeholder="0">
      </div>
      <div class="form-group">
        <label class="form-label">위험자산 여부</label>
        <select class="form-ctrl" id="f-risk">
          <option value="1">위험자산</option>
          <option value="0">안전자산</option>
        </select>
      </div>
    </div>
    <button class="btn-full" onclick="addAsset()">추가하기</button>
  </div>

  <div class="sec-label">샘플 데이터</div>
  <div class="card">
    <button class="btn-outline" onclick="loadDC()">📥 삼성 IRP (퇴직연금) 샘플</button>
    <button class="btn-outline" onclick="loadISA()">📥 나무증권 ISA 샘플</button>
    <button class="btn-outline" onclick="loadCMA()">📥 미래에셋CMA + 토스 샘플</button>
    <div style="font-size:11px;color:#aab0c4;text-align:center;margin-top:4px;">실제 잔고를 직접 입력하면 더 정확합니다</div>
  </div>

  <div class="sec-label">데이터 관리</div>
  <div class="card">
    <button class="btn-outline" onclick="exportData()">📤 JSON 내보내기</button>
    <button class="btn-outline" onclick="document.getElementById('imp').click()">📥 JSON 가져오기</button>
    <input type="file" id="imp" accept=".json" style="display:none" onchange="importData(event)">
    <button class="btn-outline" style="color:#e85555;border-color:#e85555;" onclick="if(confirm('전체 초기화?'))clearAll()">🗑 전체 초기화</button>
  </div>
</div>

<!-- Bottom nav -->
<nav class="bottom-nav">
  <button class="nav-btn active" onclick="nav('home',this)" aria-label="홈">
    <i class="ti ti-home" aria-hidden="true"></i>홈
  </button>
  <button class="nav-btn" onclick="nav('assets',this)" aria-label="자산">
    <i class="ti ti-chart-bar" aria-hidden="true"></i>자산
  </button>
  <button class="nav-btn" onclick="nav('overlap',this)" aria-label="중복분석">
    <i class="ti ti-copy" aria-hidden="true"></i>중복
  </button>
  <button class="nav-btn" onclick="nav('ai',this)" aria-label="AI">
    <i class="ti ti-sparkles" aria-hidden="true"></i>AI
  </button>
  <button class="nav-btn" onclick="nav('add',this)" aria-label="추가">
    <i class="ti ti-plus" aria-hidden="true"></i>추가
  </button>
</nav>

<script>
let assets = JSON.parse(localStorage.getItem('pf2_assets')||'[]');
let filter = 'all';
let aiHist = [];

const ACCT = {
  toss:   {label:'토스직투',    cls:'b-toss',   color:'#378ADD'},
  samsung:{label:'삼성 IRP',   cls:'b-samsung', color:'#7F77DD'},
  namu:   {label:'나무 ISA',   cls:'b-namu',    color:'#1D9E75'},
  mirae:  {label:'미래에셋',   cls:'b-mirae',   color:'#BA7517'}
};
const TYPE = {
  domestic_stock:{label:'국내주식',risk:true, icon:'ti-building',bg:'#fff0f0',ic:'#c0392b'},
  us_stock:      {label:'미국주식',risk:true, icon:'ti-world',bg:'#fff5ec',ic:'#993C1D'},
  etf_domestic:  {label:'국내ETF', risk:true, icon:'ti-chart-candle',bg:'#f0f0ff',ic:'#534AB7'},
  etf_us:        {label:'미국ETF', risk:true, icon:'ti-chart-line',bg:'#edf4ff',ic:'#185FA5'},
  fund:          {label:'펀드',    risk:true, icon:'ti-coin',bg:'#fdf0ff',ic:'#993556'},
  bond_fund:     {label:'채권형',  risk:false,icon:'ti-certificate',bg:'#edfaf4',ic:'#0F6E56'},
  tdf:           {label:'TDF',    risk:true, icon:'ti-calendar-time',bg:'#e8fbf8',ic:'#0f6e56'},
  deposit:       {label:'예금',   risk:false,icon:'ti-piggy-bank',bg:'#f7f8fc',ic:'#5F5E5A'},
  cash:          {label:'CMA',    risk:false,icon:'ti-cash',bg:'#fffbec',ic:'#854F0B'}
};

function nav(id, el) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  el.classList.add('active');
  if(id==='home') renderHome();
  if(id==='assets') renderAssets();
  if(id==='overlap') renderOverlap();
  if(id==='ai') updateAICtx();
}

function won(n) {
  if(!n&&n!==0) return '—';
  if(Math.abs(n)>=100000000) return (n/100000000).toFixed(1)+'억원';
  if(Math.abs(n)>=10000) return Math.round(n/10000).toLocaleString()+'만원';
  return n.toLocaleString()+'원';
}
function wonShort(n) {
  if(!n&&n!==0) return '—';
  if(Math.abs(n)>=100000000) return (n/100000000).toFixed(1)+'억';
  if(Math.abs(n)>=10000) return Math.round(n/10000)+'만';
  return n.toLocaleString();
}
function sim(a,b) {
  a=a.toLowerCase().replace(/\s/g,'');b=b.toLowerCase().replace(/\s/g,'');
  if(a===b)return 1;if(a.includes(b)||b.includes(a))return 0.75;
  const sa=new Set(a),sb=new Set(b),i=[...sa].filter(c=>sb.has(c)).length;
  return i/Math.max(sa.size,sb.size);
}

function renderHome() {
  const total=assets.reduce((s,a)=>s+a.value,0);
  const cost=assets.reduce((s,a)=>s+(a.qty*a.cost||0),0);
  const gain=total-cost;
  const ret=cost>0?(gain/cost*100):0;
  const irp=assets.filter(a=>a.account==='samsung');
  const irpT=irp.reduce((s,a)=>s+a.value,0);
  const irpR=irp.filter(a=>a.risk).reduce((s,a)=>s+a.value,0);
  const rr=irpT>0?(irpR/irpT*100):0;

  document.getElementById('h-total').textContent=total>0?won(total):'—';
  document.getElementById('h-total-sub').textContent=total>0?(gain>=0?'+':'')+won(gain)+' ('+(ret>=0?'+':'')+ret.toFixed(2)+'%)':'자산을 추가해주세요';
  document.getElementById('h-ret').textContent=cost>0?(ret>=0?'+':'')+ret.toFixed(1)+'%':'—';
  document.getElementById('h-cnt').textContent=assets.length>0?assets.length+'종목':'—';
  const hrisk=document.getElementById('h-risk');
  hrisk.textContent=irpT>0?rr.toFixed(1)+'%':'—';
  if(rr>70) hrisk.style.color='#ffd066'; else hrisk.style.color='';

  // IRP alert
  const alertEl=document.getElementById('irp-alert');
  if(irpT>0) {
    if(rr>70) alertEl.innerHTML=`<div class="alert a-danger"><i class="ti ti-alert-circle" style="font-size:16px;flex-shrink:0;" aria-hidden="true"></i><span>IRP 위험자산 ${rr.toFixed(2)}% — 한도(70%) 초과! 즉시 리밸런싱이 필요합니다.</span></div>`;
    else alertEl.innerHTML=`<div class="alert a-ok"><i class="ti ti-circle-check" style="font-size:16px;flex-shrink:0;" aria-hidden="true"></i><span>IRP 위험자산 ${rr.toFixed(2)}% — 한도 이내입니다.</span></div>`;
  } else alertEl.innerHTML='';

  // Account bars
  const acctT={};assets.forEach(a=>{acctT[a.account]=(acctT[a.account]||0)+a.value;});
  const acctEl=document.getElementById('acct-bars');
  if(!Object.keys(acctT).length){acctEl.innerHTML='<div class="empty"><i class="ti ti-wallet" aria-hidden="true"></i>자산을 추가하면 표시됩니다</div>';return;}
  acctEl.innerHTML=Object.entries(acctT).sort((a,b)=>b[1]-a[1]).map(([k,v])=>`
    <div class="bar-row">
      <div class="bar-label">${ACCT[k]?.label||k}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${total>0?(v/total*100).toFixed(1):0}%;background:${ACCT[k]?.color||'#888'}"></div></div>
      <div class="bar-pct">${total>0?(v/total*100).toFixed(1):0}%</div>
    </div>`).join('');

  // Top assets
  const topEl=document.getElementById('top-assets');
  if(!assets.length){topEl.innerHTML='<div class="empty"><i class="ti ti-chart-pie" aria-hidden="true"></i>자산을 추가해주세요</div>';return;}
  topEl.innerHTML=[...assets].sort((a,b)=>b.value-a.value).slice(0,6).map(a=>{
    const c=a.qty*a.cost,g=a.value-c,r=c>0?(g/c*100):0;
    const t=TYPE[a.type]||{label:a.type,icon:'ti-coin',bg:'#f7f8fc',ic:'#888'};
    return`<div class="asset-item">
      <div class="asset-icon" style="background:${t.bg}"><i class="ti ${t.icon}" style="color:${t.ic};font-size:17px;" aria-hidden="true"></i></div>
      <div class="asset-info">
        <div class="asset-name">${a.name}</div>
        <div class="asset-meta"><span class="badge ${ACCT[a.account]?.cls||''}">${ACCT[a.account]?.label||a.account}</span> ${t.label}</div>
      </div>
      <div class="asset-right">
        <div class="asset-value mono">${wonShort(a.value)}</div>
        <div class="asset-ret ${c>0?(r>=0?'up':'down'):''}">${c>0?(r>=0?'+':'')+r.toFixed(1)+'%':'—'}</div>
      </div>
    </div>`;
  }).join('');
}

function setFilter(f){filter=f;renderAssets();}
function renderAssets() {
