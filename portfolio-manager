  const type=document.getElementById('f-type').value;
  assets.push({id:Date.now(),account:document.getElementById('f-acct').value,type,name,qty:parseFloat(document.getElementById('f-qty').value)||0,cost:parseFloat(document.getElementById('f-cost').value)||0,value,risk:document.getElementById('f-risk').value==='1'});
  save();['f-name','f-qty','f-cost','f-value'].forEach(id=>document.getElementById(id).value='');
  alert(`'${name}' 추가 완료!`);
}

