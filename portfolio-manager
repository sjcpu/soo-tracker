  const total=assets.reduce((s,a)=>s+a.value,0);
  el.innerHTML=[...list].sort((a,b)=>b.value-a.value).map(a=>{
    const c=a.qty*a.cost,g=a.value-c,r=c>0?(g/c*100):0;
    const t=TYPE[a.type]||{label:a.type,icon:'ti-coin',bg:'#f7f8fc',ic:'#888'};
    const idx=assets.indexOf(a);
    return`<div class="asset-item">
      <div class="asset-icon" style="background:${t.bg}"><i class="ti ${t.icon}" style="color:${t.ic};font-size:17px;" aria-hidden="true"></i></div>
