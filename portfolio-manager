function renderOverlap() {
  const el=document.getElementById('overlap-body');
  if(assets.length<2){el.innerHTML='<div class="empty" style="padding-top:40px;"><i class="ti ti-copy" aria-hidden="true"></i>자산을 2개 이상 추가하면<br>중복 분석이 가능합니다</div>';return;}
  const ovs=[];
  for(let i=0;i<assets.length;i++)for(let j=i+1;j<assets.length;j++){
    if(sim(assets[i].name,assets[j].name)>0.5) ovs.push({a:assets[i],b:assets[j]});
  }
  const tg={};assets.forEach(a=>{(tg[a.type]=tg[a.type]||[]).push(a);});
  const cats=Object.entries(tg).filter(([t,arr])=>arr.length>1&&['domestic_stock','us_stock','etf_domestic','etf_us','fund','tdf'].includes(t));

  let html='';
  if(!ovs.length&&!cats.length){el.innerHTML='<div class="alert a-ok" style="margin-top:16px;"><i class="ti ti-circle-check" style="font-size:16px;" aria-hidden="true"></i> 중복 투자가 감지되지 않았습니다.</div>';return;}

  if(ovs.length){
    html+=`<div class="alert a-warn"><i class="ti ti-alert-triangle" style="font-size:16px;flex-shrink:0;" aria-hidden="true"></i>${ovs.length}건의 동일/유사 종목 중복이 감지되었습니다.</div>`;
    html+=ovs.map(o=>`<div class="overlap-card">
      <div class="overlap-title">${o.a.name} ↔ ${o.b.name}</div>
      <div class="overlap-detail"><span class="badge ${ACCT[o.a.account]?.cls||''}">${ACCT[o.a.account]?.label}</span> ${wonShort(o.a.value)} + <span class="badge ${ACCT[o.b.account]?.cls||''}">${ACCT[o.b.account]?.label}</span> ${wonShort(o.b.value)}</div>
      <div class="overlap-tip">💡 세금 효율: ISA > IRP > 직투. 한 계좌로 통합을 검토하세요.</div>
    </div>`).join('');
  }
  if(cats.length){
    html+='<div class="sec-label" style="margin-top:16px;">유형별 중복 보유</div>';
    html+=cats.map(([t,arr])=>`<div class="overlap-card">
      <div class="overlap-title">${TYPE[t]?.label||t} — ${arr.length}개 계좌에 분산</div>
      <div class="overlap-detail">${arr.map(a=>`<span class="badge ${ACCT[a.account]?.cls||''}">${ACCT[a.account]?.label}</span>`).join(' ')}</div>
      <div class="overlap-tip">💡 같은 유형은 계좌 역할을 구분하거나 통합하세요.</div>
    </div>`).join('');
  }
  el.innerHTML=html;
}

