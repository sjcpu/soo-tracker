function pfSummary() {
  if(!assets.length) return '(보유 자산 없음)';
  const total=assets.reduce((s,a)=>s+a.value,0);
  return`총 ${won(total)}\n`+assets.map(a=>`- [${ACCT[a.account]?.label}] ${a.name}(${TYPE[a.type]?.label}): ${won(a.value)} (${(a.value/total*100).toFixed(1)}%)`).join('\n');
}

async function sendAI() {
  const inp=document.getElementById('ai-in'),btn=document.getElementById('ai-btn');
  const msg=inp.value.trim();if(!msg)return;
  addMsg('user',msg);inp.value='';btn.disabled=true;
  const sys=`당신은 한국 개인 투자자를 위한 전문 투자 어드바이저입니다.
계좌: 토스직투(국내주식), 삼성증권IRP(퇴직연금), 나무증권ISA, 미래에셋CMA
포트폴리오:\n${pfSummary()}
역할: 중복투자 분석, 계좌별 절세(ISA비과세·IRP세액공제), 매수/매도 추천, IRP위험자산 70%한도 관리, 2026년 시장상황 반영.
간결하고 실행가능하게 답변하세요.`;
  const lid='l'+Date.now();
  const me=document.getElementById('ai-msgs');
  me.innerHTML+=`<div class="msg" id="${lid}"><div class="avatar av-ai">AI</div><div class="bubble bubble-ai"><div class="loading"><div class="spinner"></div>분석 중...</div></div></div>`;
  me.scrollTop=me.scrollHeight;
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:sys,messages:[...aiHist,{role:'user',content:msg}]})});
    const d=await r.json();
    const rep=d.content?.[0]?.text||'응답 없음';
    document.getElementById(lid)?.remove();
    addMsg('ai',rep);
    aiHist.push({role:'user',content:msg},{role:'assistant',content:rep});
    if(aiHist.length>20)aiHist=aiHist.slice(-20);
  }catch{document.getElementById(lid)?.remove();addMsg('ai','오류가 발생했습니다. 다시 시도해주세요.');}
  btn.disabled=false;
}

