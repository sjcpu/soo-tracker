        <div class="asset-name">${a.name}</div>
        <div class="asset-meta"><span class="badge ${ACCT[a.account]?.cls||''}">${ACCT[a.account]?.label||a.account}</span> · ${wonShort(a.value)} · ${total>0?(a.value/total*100).toFixed(1):0}%</div>
      </div>
